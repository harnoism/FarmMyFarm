<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.MenuController"
            prefWidth="1100" prefHeight="650"
            style="-fx-background-image: url('/image/FarmMyFarm.png');
                   -fx-background-repeat: no-repeat;
                   -fx-background-size: cover;
                   -fx-background-position: center center;">

   <!-- Titre principal -->
   <Label layoutX="0" layoutY="80" prefWidth="1100"
          text="🌾 FarmMyFarm"
          alignment="CENTER"
          style="-fx-font-size: 64px;
                  -fx-font-weight: bold;
                  -fx-text-fill: #f5e6c8;
                  -fx-effect: dropshadow( gaussian , #000000 , 4 , 0 , 2 , 2 );" />

   <!-- Sous-titre -->
   <Label layoutX="0" layoutY="180" prefWidth="1100"
          text="Le jeu de ferme ultime"
          alignment="CENTER"
          style="-fx-font-size: 24px;
                  -fx-text-fill: #a5c87a;
                  -fx-effect: dropshadow( gaussian , #000000 , 2 , 0 , 1 , 1 );" />

   <!-- Boutons centrés -->
   <VBox alignment="CENTER" layoutX="400" layoutY="300" prefWidth="300" spacing="20">

      <Button onAction="#nouvellePartie"
              text="🌱 Nouvelle Partie"
              prefWidth="280" prefHeight="55"
              style="-fx-background-color: #4a9e30;
                       -fx-text-fill: white;
                       -fx-font-size: 20px;
                       -fx-font-weight: bold;
                       -fx-background-radius: 12;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow( gaussian , rgba(0,0,0,0.6) , 4 , 0 , 2 , 2 );" />

      <Button onAction="#chargerPartie"
              fx:id="btnCharger"
              text="💾 Charger la Partie"
              prefWidth="280" prefHeight="55"
              style="-fx-background-color: #795548;
                       -fx-text-fill: white;
                       -fx-font-size: 20px;
                       -fx-font-weight: bold;
                       -fx-background-radius: 12;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow( gaussian , rgba(0,0,0,0.6) , 4 , 0 , 2 , 2 );" />

      <Button onAction="#quitter"
              text="❌ Quitter"
              prefWidth="280" prefHeight="55"
              style="-fx-background-color: #8b2020;
                       -fx-text-fill: white;
                       -fx-font-size: 20px;
                       -fx-font-weight: bold;
                       -fx-background-radius: 12;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow( gaussian , rgba(0,0,0,0.6) , 4 , 0 , 2 , 2 );" />

   </VBox>

</AnchorPane>