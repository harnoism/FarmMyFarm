<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<AnchorPane fx:id="root" prefHeight="151.0" prefWidth="334.0" style="-fx-background-color: #38713e; -fx-padding: 10;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.ModalChoicePlant">


    <TabPane layoutX="0" layoutY="35" prefHeight="194.0" prefWidth="362.0" tabClosingPolicy="UNAVAILABLE">
        <tabs>

            <Tab text="Plantes">
                <content>

                    <GridPane alignment="CENTER" hgap="10" prefHeight="198.0" prefWidth="320.0" style="-fx-padding: 16; -fx-background-color: #38713e;" vgap="14">

                        <Button fx:id="btnPatate" onAction="#choosePatate" prefHeight="60" prefWidth="82" text="Patate" GridPane.columnIndex="0" GridPane.rowIndex="0" />

                        <Button fx:id="btnMais" onAction="#chooseMais" prefHeight="60" prefWidth="82" text="Mais" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Button fx:id="btnCarrot" onAction="#chooseCarrot" prefHeight="60" prefWidth="82" text="Carotte" GridPane.columnIndex="2" GridPane.rowIndex="0" />

                        <Button fx:id="btnBrocoli" onAction="#chooseBrocoli" prefHeight="60" prefWidth="82" text="Brocoli" GridPane.columnIndex="0" GridPane.rowIndex="1" />

                        <Button fx:id="btnTomate" onAction="#chooseTomate" prefHeight="60" prefWidth="82" text="Tomate" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <columnConstraints>
                     <ColumnConstraints />
                     <ColumnConstraints />
                     <ColumnConstraints />
                  </columnConstraints>
                  <rowConstraints>
                     <RowConstraints />
                     <RowConstraints />
                  </rowConstraints>
                    </GridPane>
                </content>
            </Tab>

            <Tab text="Animaux">
                <content>
                    <GridPane alignment="CENTER" hgap="10" style="-fx-padding: 16; -fx-background-color: #38713e;" vgap="14">

                        <Button fx:id="btnPoule" onAction="#choosePoule" prefHeight="60" prefWidth="82" text="Poule" GridPane.columnIndex="0" GridPane.rowIndex="0" />

                        <Button fx:id="btnVache" onAction="#chooseVache" prefHeight="60" prefWidth="82" text="Vache" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Button fx:id="btnCochon" onAction="#chooseCochon" prefHeight="60" prefWidth="82" text="Cochon" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                  <columnConstraints>
                     <ColumnConstraints />
                     <ColumnConstraints />
                     <ColumnConstraints />
                  </columnConstraints>
                  <rowConstraints>
                     <RowConstraints />
                  </rowConstraints>

                    </GridPane>
                </content>
            </Tab>

        </tabs>
    </TabPane>

</AnchorPane>
