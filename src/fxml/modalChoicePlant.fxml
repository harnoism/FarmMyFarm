<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.Label?>

<GridPane xmlns="http://javafx.com/javafx"
          xmlns:fx="http://javafx.com/fxml"
          fx:controller="Controller.ModalChoicePlant"
          fx:id="root"
          alignment="CENTER"
          hgap="10"
          vgap="14"
          prefWidth="320"
          prefHeight="240"
          style="-fx-padding: 24;
                 -fx-background-color: #38713e;">

    <Label text="🌱 Choisir une plante"
           GridPane.columnIndex="0"
           GridPane.rowIndex="0"
           GridPane.columnSpan="3"
           GridPane.halignment="CENTER"
           style="-fx-font-size: 16px;
           -fx-font-family: 'Segoe UI Emoji'; +
                  -fx-font-weight: bold;
                  -fx-text-fill: #f5e6c8;
                  -fx-padding: 0 0 6 0;"/>

    <Button text="🥔 Patate"
            fx:id="btnPatate"
            prefWidth="82" prefHeight="60"
            GridPane.columnIndex="0"
            GridPane.rowIndex="1"
            onAction="#choosePatate"/>

    <Button text="🌽 Maïs"
            fx:id="btnMais"
            prefWidth="82" prefHeight="60"
            GridPane.columnIndex="1"
            GridPane.rowIndex="1"
            onAction="#chooseMais"/>

    <Button text="🥕 Carotte"
            fx:id="btnCarrot"
            prefWidth="82" prefHeight="60"
            GridPane.columnIndex="2"
            GridPane.rowIndex="1"
            onAction="#chooseCarrot"/>

    <Button text="🥦 Brocoli"
            fx:id="btnBrocoli"
            prefWidth="82" prefHeight="60"
            GridPane.columnIndex="0"
            GridPane.rowIndex="2"
            onAction="#chooseBrocoli"/>

    <Button text="🍅 Tomate"
            fx:id="btnTomate"
            prefWidth="82" prefHeight="60"
            GridPane.columnIndex="1"
            GridPane.rowIndex="2"
            onAction="#chooseTomate"/>

</GridPane>